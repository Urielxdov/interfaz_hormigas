{
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "target": "ESNext",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@hormigas/domain": ["packages/domain"],
      "@hormigas/application": ["packages/application"],
      "@hormigas/infrastructure": ["packages/infrastructure"]
    }
  }
}
